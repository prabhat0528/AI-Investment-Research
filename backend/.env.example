# Server Configuration
PORT=5000

# PostgreSQL Connection String (Replace with your local Postgres or Supabase connection string)
DATABASE_URL=postgresql://postgres:password@localhost:5432/invest_agent

# JWT Secret Key (Any random string used for secure token signing)
JWT_SECRET=super_secret_jwt_key_change_me_in_production

# Google Gemini API Key (Obtain from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here
